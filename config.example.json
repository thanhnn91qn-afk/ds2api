  "thinking_injection": {
    "enabled": true,
    "prompt": ""
  },
  "embeddings": {
    "provider": "deterministic"
  },
  "admin": {
    "jwt_expire_hours": 24
  },
  "runtime": {
    "account_max_inflight": 2,
    "account_max_queue": 0,
    "global_max_inflight": 0,
    "token_refresh_interval_hours": 6
  },
  "auto_delete": {
    "mode": "none"
  }
